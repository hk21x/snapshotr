# Snapshotr - Environment Variables
# All settings can also be configured via the web UI (saved to config.json).
# Environment variables take precedence over config.json values.

# Camera RTSPS stream URL
# RTSP_URL=rtsps://192.168.1.1:7441/your-stream-id

# Capture interval in minutes (1-1440)
# INTERVAL_MINUTES=5

# JPEG quality (1 = best, 31 = smallest)
# JPEG_QUALITY=2

# Absolute path for saved snapshots
# IMAGE_DIR=/data/images

# Directory containing config.json (default: working directory)
# CONFIG_DIR=/app

# Timezone for snapshot timestamps (e.g. Europe/London, America/New_York).
# Leave unset to use the host's local time. Defaults to UTC if neither this
# nor the host clock is available.
# TZ=Europe/London

# Discord webhook for failure alerts
# DISCORD_ENABLED=true
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# API key for authentication (leave unset to disable auth)
# API_KEY=your-secret-key-here

# Snapshot retention policy
# RETENTION_ENABLED=true
# RETENTION_MAX_AGE_DAYS=30
# RETENTION_MAX_TOTAL_MB=0
